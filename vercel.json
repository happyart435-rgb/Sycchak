{
  "version": 2,
  "builds": [
    { "src": "api/get_balance.js", "use": "@vercel/node" },
    { "src": "api/update_balance.js", "use": "@vercel/node" },
    { "src": "api/get_leaders.js", "use": "@vercel/node" },
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "**/!(api)/*", "use": "@vercel/static" },
    { "src": "*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/get_balance/:userId", "destination": "api/get_balance.js?user_id=:userId" },
    { "source": "/api/update_balance", "destination": "api/update_balance.js" },
    { "source": "/api/get_leaders", "destination": "api/get_leaders.js" },
    { "source": "/api/(.*)", "destination": "api/index.py" },
    { "source": "/((?!api/|.*\\.html$).*)", "destination": "/index.html" }
  ]
}
